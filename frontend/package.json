{
  "name": "replication-strategies-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "bff": "bun run server/bff.ts",
    "dev": "bun run server/bff.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/main.ts --outdir dist --sourcemap --minify",
    "e2e": "node e2e-run.mjs",
    "dev:hmr": "DEV_HMR=1 bun run server/bff.ts",
    "test": "bun test",
    "generate:types": "openapi-typescript ../gateway/openapi.yaml -o src/api/generated.ts",
    "check:types-drift": "bun run generate:types && git diff --exit-code src/api/generated.ts"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/cors": "^1.4.1",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/d3": "^7.4.3",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.11",
    "openapi-typescript": "7",
    "typescript": "^5.0.0"
  }
}
